# Secrets y configuración local
*.env
*.local
*.secret
secrets/
credentials/
.env.*

# Ansible — datos reales (usar los .example como plantilla, nunca commitear estos)
**/ansible/ansible.cfg
**/ansible/inventory/hosts.yml
**/ansible/inventory/group_vars/all.yml
**/ansible/inventory/host_vars/
**/ansible/.vault_pass
**/ansible/vault_pass.txt
**/ansible/*.retry
# Excepción: hosts.yml y all.yml CIFRADOS con ansible-vault sí se versionan
!**/ansible/inventory/hosts.vault.yml
!**/ansible/inventory/group_vars/all.vault.yml

# Vault password file — nunca se commitea, vive en el home del usuario
.vault_pass_infra-utils

# Backups generados por los scripts
*.bak
*.bak.*

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/
