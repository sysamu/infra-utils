## Managed by Ansible — do not edit manually
check system $HOST
  if loadavg (1min) > 4 for 5 cycles then alert
  if loadavg (5min) > 2 for 10 cycles then alert
  if cpu usage (user) > {{ monit_cpu_user_warn }}% for {{ monit_cpu_cycles }} cycles then alert
  if cpu usage (user) > {{ monit_cpu_user_crit }}% for {{ monit_cpu_cycles }} cycles then alert
  if memory usage > {{ monit_mem_warn }}% for 5 cycles then alert
  if memory usage > {{ monit_mem_crit }}% for 5 cycles then alert
