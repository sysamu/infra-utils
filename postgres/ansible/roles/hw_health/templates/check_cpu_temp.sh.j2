#!/bin/bash
# Temperatura de CPU via lm-sensors.
# Monitoriza: Package id (Intel), Tctl/Tdie (AMD).
# Evalua todos los packages — reporta todos, alerta si cualquiera supera umbral.

CPU_WARN={{ cpu_temp_warn_c }}
CPU_CRIT={{ cpu_temp_crit_c }}

{% raw %}
if ! command -v sensors &>/dev/null; then
  echo "UNKNOWN: lm-sensors not installed"
  exit 3
fi

OUTPUT=$(sensors 2>/dev/null)
if [[ -z "$OUTPUT" ]]; then
  echo "UNKNOWN: sensors returned no data"
  exit 3
fi

CPU_SENSORS=()

while IFS= read -r line; do
  if [[ "$line" =~ ^(Package\ id\ [0-9]+|Tctl|Tdie)[[:space:]]*:[[:space:]]*\+([0-9]+)\. ]]; then
    CPU_SENSORS+=("${BASH_REMATCH[1]}:${BASH_REMATCH[2]}")
  fi
done <<< "$OUTPUT"

if [[ ${#CPU_SENSORS[@]} -eq 0 ]]; then
  echo "UNKNOWN: no CPU temperature sensors found"
  exit 3
fi

SUMMARY=""
for S in "${CPU_SENSORS[@]}"; do
  SUMMARY+="CPU(${S%%:*})=${S##*:}C "
done
SUMMARY="${SUMMARY% }"

WORST_STATE=0
WORST_MSG=""

for S in "${CPU_SENSORS[@]}"; do
  LABEL="${S%%:*}"; TEMP="${S##*:}"
{% endraw %}
  if (( TEMP >= CPU_CRIT )); then
    [[ $WORST_STATE -lt 2 ]] && { WORST_STATE=2; WORST_MSG="CRITICAL: ${LABEL}=${TEMP}C (crit=${CPU_CRIT}C)"; }
  elif (( TEMP >= CPU_WARN )); then
    [[ $WORST_STATE -lt 1 ]] && { WORST_STATE=1; WORST_MSG="WARNING: ${LABEL}=${TEMP}C (warn=${CPU_WARN}C)"; }
  fi
{% raw %}
done

echo "${WORST_MSG:+${WORST_MSG} -- }${SUMMARY}"
exit $WORST_STATE
{% endraw %}
